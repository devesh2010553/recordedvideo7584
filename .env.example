# Copy this to .env for local development

# MongoDB Atlas connection string (required — data will not persist without this)
# Create a free cluster at https://cloud.mongodb.com → Get connection string → Node.js driver
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/pulse?retryWrites=true&w=majority

# Admin dashboard password
ADMIN_PASSWORD=change-me-before-deploying

# Secret for signing auth cookies (any long random string)
SESSION_SECRET=change-me-before-deploying

# VAPID keys for Web Push notifications
# Run: npm run generate-vapid
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
