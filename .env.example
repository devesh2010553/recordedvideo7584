# Copy this file to .env for local development.
# On Render, set these in the dashboard under Environment.

# Required: MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/pulse_location_share?retryWrites=true&w=majority
MONGODB_DB=pulse_location_share

# Password the admin uses to sign in to /admin
ADMIN_PASSWORD=change-me

# Random long string used to sign the admin session cookie
SESSION_SECRET=change-this-to-a-long-random-string

# Generate with: npm run generate-vapid
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# Optional - Render sets PORT automatically, this is only for local runs
PORT=3000
